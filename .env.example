# Environment variables configuration for HealthBot
# Copy this file as .env and fill in with your actual keys

# OpenAI API Key (RECOMMENDED - Paid but most capable)
# Get your key at: https://platform.openai.com/api-keys
# Note: Requires paid OpenAI account with credits
OPENAI_API_KEY=sk-your-key-here

# Tavily Search API Key (required for search)
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Optional configurations
# OpenAI Model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Model temperature (0 = deterministic, 1 = creative)
# LLM_TEMPERATURE=0.7

# Maximum Tavily search results (default: 5)
# TAVILY_MAX_RESULTS=5
